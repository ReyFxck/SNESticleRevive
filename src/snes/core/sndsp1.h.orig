/*
 * sndsp1.h - DSP-1 / DSP-1B coprocessor emulation header
 *
 * Implementacao clean-room baseada apenas em documentacao publica:
 *   - https://snes.nesdev.org/wiki/DSP-1
 *   - https://www.sneslab.net/wiki/DSP-1   (e subpaginas DSP1/<comando>)
 *   - SNES Development Manual Book II, Cap. 3-5 (referencias citadas)
 *   - Matematica de projecao por pinhole / Mode-7 (textbook 3D graphics)
 *
 * Nada deste arquivo foi copiado de bsnes / snes9x / Snes9xGX / etc.
 */
#ifndef _SNDSP1_H
#define _SNDSP1_H

#include "sndsp.h"

class SNDSP1 : public ISNDSP
{
public:
    SNDSP1();

    // ISNDSP
    void  Reset();
    void  WriteData(Uint32 uAddr, Uint8 uData);
    Uint8 ReadData (Uint32 uAddr);
    Uint8 ReadStatus(Uint32 uAddr);

    static SNDSP1 *GetInstance();

private:
    // -----------------------------------------------------------------
    // Maquina de estados do barramento.
    //
    // O DSP-1 e visto pela CPU como um par de registradores de 8 bits:
    //   DR  (Data Register) - byte-stream R/W
    //   SR  (Status Register) - somente leitura, bit 7 = DRC (data req)
    //
    // O firmware interno guia a CPU em fases:
    //   PHASE_CMD   - espera o byte de opcode
    //   PHASE_IN    - le N bytes (2 por palavra) ate completar inSize
    //   PHASE_OUT   - emite M bytes (2 por palavra) ate completar outSize
    //
    // O endereco da escrita/leitura NAO importa para o chip real - e um
    // stream linear. Esse ponto era o bug principal do codigo antigo.
    // -----------------------------------------------------------------
    enum Phase { PHASE_CMD = 0, PHASE_IN = 1, PHASE_OUT = 2 };

    Uint8   m_ePhase;
    Uint8   m_uCmd;        // ultimo opcode aceito
    Uint8   m_uInBytes;    // bytes ja recebidos para a entrada atual
    Uint8   m_uOutBytes;   // bytes ja entregues da saida atual
    Uint8   m_uInSize;     // bytes esperados (= 2 * #palavras)
    Uint8   m_uOutSize;    // bytes a emitir   (= 2 * #palavras)

    // buffers de palavras 16-bit (16 palavras = 32 bytes, suficiente
    // para qualquer comando DSP-1; o maior e' Parameter com 7 entradas)
    Int16   m_InData [16];
    Int16   m_OutData[16];

    // -----------------------------------------------------------------
    // Estado mantido entre chamadas:
    //   - matrizes geradas por Attitude (A/B/C)
    //   - parametros de camera setados por Parameter (usados por Raster
    //     e Project para projetar pontos / scanlines)
    // -----------------------------------------------------------------
    // Attitude: trinca de matrizes 3x3 (A, B, C), uma para cada banco
    Int16   m_Att   [3][3][3];  // [banco][linha][coluna], formato 1.15
    Int16   m_AttScale[3];      // escala aplicada a cada banco

    // Parameter:
    Int16   m_Fx, m_Fy, m_Fz;   // posicao do foco da camera (mundo)
    Int16   m_Lfe;              // distancia foco -> olho
    Int16   m_Les;              // distancia olho -> tela (focal length)
    Int16   m_Aas;              // angulo de atitude (pitch)
    Int16   m_Azs;              // angulo Z (yaw)
    Int16   m_Vof;              // offset vertical (linha do horizonte)
    Int16   m_Vva;              // raster lines visiveis abaixo do horizonte
    Int16   m_Cx, m_Cy;         // centro da tela (BG space)

    // Versao "B" do Parameter (com Aas2/Azs2 inv) - alguns jogos chamam
    Int16   m_SinAas, m_CosAas;
    Int16   m_SinAzs, m_CosAzs;

    void Execute();
};

#endif
